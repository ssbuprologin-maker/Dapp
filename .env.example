VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com
# Public devnet wallet that receives the 0.01 SOL round entry fees.
JOIN_FEE_RECEIVER=YOUR_DEVNET_FEE_WALLET
# JSON array containing the 64 secret-key bytes for the same dedicated devnet wallet.
PAYOUT_WALLET_SECRET_KEY=[]
# Long random value used by Vercel to authorize the hourly cron request.
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
# Comma-separated wallet addresses allowed into the game. Ignored when ALLOW_ALL_PLAYERS=true.
PLAYER_WHITELIST=YOUR_WALLET_ADDRESS,SECOND_WALLET_ADDRESS
# Add from a Redis integration in the Vercel Marketplace.
REDIS_URL=
# Set true to allow any wallet to play.
ALLOW_ALL_PLAYERS=false
