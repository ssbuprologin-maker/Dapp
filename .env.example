VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com
# Public devnet wallet that receives the 0.01 SOL round entry fees.
JOIN_FEE_RECEIVER=YOUR_DEVNET_FEE_WALLET
# Comma-separated wallet addresses allowed into the game.
PLAYER_WHITELIST=YOUR_WALLET_ADDRESS,SECOND_WALLET_ADDRESS
# Add from a Redis integration in the Vercel Marketplace.
REDIS_URL=
# Set true only for local testing. Keep false in Vercel.
ALLOW_ALL_PLAYERS=false
