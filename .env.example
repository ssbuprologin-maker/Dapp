# Optional overrides. Leave blank to use the built-in free devnet fallback.
VITE_SOLANA_RPC_URL=
SOLANA_RPC_URL=
# Server-only base58 private key for the dedicated devnet receiver wallet. Never use a VITE_ prefix.
PAYOUT_WALLET_PRIVATE_KEY=

# Public PostHog browser settings. Use the host shown by your PostHog project.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Server-only Upstash Redis REST credentials. Never use a VITE_ prefix.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
