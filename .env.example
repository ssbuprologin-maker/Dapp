# Optional overrides. Leave blank to use the built-in free devnet fallback.
VITE_SOLANA_RPC_URL=
SOLANA_RPC_URL=
# Optional legacy 2x game-payout signer only. The planned chat airdrop does not
# use this variable: contributions are incoming-only and prizes are site vouchers.
# Never use a VITE_ prefix or expose a real-value wallet key.
PAYOUT_WALLET_PRIVATE_KEY=

# Public PostHog browser settings. Use the host shown by your PostHog project.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Server-only Upstash Redis REST credentials. Never use a VITE_ prefix.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-only Ably key for WebSocket live chat. Never use a VITE_ prefix.
ABLY_API_KEY=
